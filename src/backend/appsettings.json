{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Validation": {
    "Skipping": {
      "SkipBeforeTableOfContents": true,
      "SkipTextBoxes": true,
      "SkipTableOfContentsContent": true
    },
    "Rules": {
      "EmptySectionStructureRule": {
        "Availability": "Available",
        "Severity": "Error"
      },
      "FontFamilyRule": {
        "Availability": "Available",
        "Severity": "Warning",
        "RequiredFontFamily": "Times New Roman"
      },
      "SingleSpaceRule": {
        "Availability": "Available",
        "Severity": "Error"
      },
      "TextJustificationRule": {
        "Availability": "Available",
        "Severity": "Error"
      },
      "NoDotsInTitlesRule": {
        "Availability": "Available",
        "Severity": "Error",
        "TargetStylePatterns": [
          "heading",
          "nagwek",
          "title",
          "tytu",
          "subtitle",
          "podtytu",
          "caption",
          "podpis"
        ]
      },
      "HeadingStyleUsageRule": {
        "Availability": "Available",
        "Severity": "Warning",
        "FontSizeThresholdAboveBodyPt": 2,
        "MaxHeadingTextLength": 200
      },
      "HierarchyDepthRule": {
        "Availability": "Available",
        "Severity": "Error",
        "MaxAllowedLevel": 3
      },
      "LineSpacingDependencyRule": {
        "Availability": "Available",
        "Severity": "Error",
        "TargetLineSpacingTwips": 360
      },
      "ParagraphSpacingRule": {
        "Availability": "Available",
        "Severity": "Error",
        "AllowedSpacingPoints": [0, 6]
      },
      "ParagraphIndentRule": {
        "Availability": "Available",
        "Severity": "Error",
        "AllowedIndentTwips": [567, 709],
        "ToleranceTwips": 60
      },
      "TocRule": {
        "Availability": "Available",
        "Severity": "Error"
      },
      "ManualTableOfContentsRule": {
        "Availability": "Available",
        "Severity": "Warning"
      },
      "MissingFigureCaptionRule": {
        "Availability": "Available",
        "Severity": "Error"
      },
      "MissingTableCaptionRule": {
        "Availability": "Available",
        "Severity": "Error"
      },
      "MissingTextBoxCaptionRule": {
        "Availability": "Available",
        "Severity": "Warning"
      },
      "FigureCaptionPositionRule": {
        "Availability": "Available",
        "Severity": "Error"
      },
      "TableCaptionPositionRule": {
        "Availability": "Available",
        "Severity": "Warning"
      },
      "FigureCaptionFormatRule": {
        "Availability": "Available",
        "Severity": "Error"
      },
      "GrammarRule": {
        "Availability": "Available",
        "Severity": "Error"
      },
      "ListPunctuationConsistencyRule": {
        "Availability": "Available",
        "Severity": "Error"
      },
      "ListIndentationConsistencyRule": {
        "Availability": "Available",
        "Severity": "Error"
      }
    },
    "CodeBlockDetection": {
      "MinimumCodeFontTextRatio": 0.2,
      "RequireWholeParagraphMonospace": false,
      "CodeFonts": [
        "Consolas",
        "Courier New",
        "Courier",
        "Lucida Console",
        "Cascadia Code",
        "Cascadia Mono",
        "JetBrains Mono",
        "Fira Code",
        "Source Code Pro",
        "Menlo",
        "Monaco",
        "DejaVu Sans Mono",
        "Liberation Mono"
      ]
    }
  },
  "LanguageTool": {
    "BaseUrl": "http://localhost:8010"
  }
}
